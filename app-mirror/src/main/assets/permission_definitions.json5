        { id: "vpn", nameKey: "perm_vpn_name", descKey: "perm_vpn_desc", icon: "🔒", required: true },
        { id: "accessibility", nameKey: "perm_accessibility_name", descKey: "perm_accessibility_desc", icon: "♿", required: true }
      ]
    },
    {
      groupId: "interface_monitor",
      groupNameKey: "interface_monitor_name",
      groupDescKey: "interface_monitor_desc",
      icon: "🖥️",
      permissions: [
        { id: "overlay", nameKey: "perm_overlay_name", descKey: "perm_overlay_desc", icon: "🪟", required: false },
        { id: "notification", nameKey: "perm_notification_name", descKey: "perm_notification_desc", icon: "🔔", required: false },
        { id: "files", nameKey: "perm_files_name", descKey: "perm_files_desc", icon: "📁", required: false }
