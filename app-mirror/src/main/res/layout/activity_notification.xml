<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:background="#E61A1A1A" android:orientation="horizontal"
        android:padding="14dp"
        android:elevation="8dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_alert_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/orbit_alert_title"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_alert_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="@string/orbit_alert_desc"
                android:textColor="#CCCCCC"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_gravity="center_vertical">

            <Button
                android:id="@+id/btn_ignore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/orbit_btn_ignore"
                android:textColor="#FFFFFF"
                android:backgroundTint="#555555"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="36dp" />

            <Button
                android:id="@+id/btn_disconnect"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/orbit_btn_disconnect"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF4444"
                android:layout_marginTop="8dp"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="36dp" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>