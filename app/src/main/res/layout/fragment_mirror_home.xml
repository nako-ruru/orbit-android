<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal">
        
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/shizukuStatusPrefix"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shizuku 权限状态: " />

            <TextView
                android:id="@+id/shizukuStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/shizukuPermissionBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="授权"
                android:visibility="gone" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/aboutBtn"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="关于"
            android:src="@drawable/ic_info_24" />
    </LinearLayout>

    <TextView
        android:id="@+id/connectScreenLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_gravity="center_horizontal"
        android:text="请连接屏幕，USB2.0手机需要Displaylink扩展坞"
        android:textSize="24sp"
        android:textStyle="bold" />

</LinearLayout>